# --- Database (Supabase Postgres connection string, pgvector enabled) -------
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# --- Auth.js ------------------------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET=""

# Google/GitHub OAuth are not wired up yet — sign-in is name/email/password
# only for now (see lib/auth.ts). Re-add as provider entries there once
# these are actually configured.

# Resend (email verification delivery, sent at signup). If unset, codes are
# logged to the server console instead — fine for local development.
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# --- AI stack -------------------------------------------------------------
ANTHROPIC_API_KEY=""
VOYAGE_API_KEY=""

# Voice interviews: speech-to-text always runs in-browser via the Web Speech
# API — no key needed. Text-to-speech prefers ElevenLabs for a more natural
# voice; if ELEVENLABS_API_KEY is unset, invalid, or the account runs out of
# credits, it automatically falls back to the browser's built-in
# SpeechSynthesis per-question — so this is safe to leave unset, and safe to
# blank out later to force browser TTS.
ELEVENLABS_API_KEY=""
# Defaults to "Adam" (a natural male voice) if left unset — override with any
# voice ID from elevenlabs.io/app/voice-library.
ELEVENLABS_VOICE_ID=""

# --- Storage (Supabase Storage, S3-compatible) ------------------------------
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Redis (Upstash, for BullMQ) --------------------------------------------
REDIS_URL=""
